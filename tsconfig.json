{
  "$schema": "https://www.schemastore.org/tsconfig",
  "display": "Node 20",

  "compilerOptions": {
    "lib": ["es2023"],
    "target": "es2022",

    "module": "nodenext",
    "moduleResolution": "nodenext",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "outDir": "dist"
  },

  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}